# Anthropic Claude API key. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the default Anthropic model.
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Free-tier LLM (recommended). https://console.groq.com/keys
# Used for generate + refine when selected (or via Auto).
GROQ_API_KEY=

# Optional Groq model.
GROQ_MODEL=llama-3.3-70b-versatile

# --- Auth (role-based access) ---
# Secret used to sign session cookies. Set a long random value in production.
NOVA_SECRET=

# Users as "user:password:role" entries, comma-separated. role = admin | member.
# If unset, demo accounts admin/nova (admin) and member/nova (member) are used.
NOVA_USERS=

# Optional: GitHub PAT for private repos (Test Generator GitHub fetch).
# Public files work without this. Fine-grained: Contents (read) on the target repos.
GITHUB_TOKEN=
