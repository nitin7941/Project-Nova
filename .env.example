# Anthropic Claude API key. Get one at https://console.anthropic.com/
# If left empty, Project Nova runs in MOCK mode so the demo still works.
ANTHROPIC_API_KEY=

# Optional: override the default model.
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Auth (role-based access) ---
# Secret used to sign session cookies. Set a long random value in production.
NOVA_SECRET=

# Users as "user:password:role" entries, comma-separated. role = admin | member.
# If unset, demo accounts admin/nova (admin) and member/nova (member) are used.
NOVA_USERS=
