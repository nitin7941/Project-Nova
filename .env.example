# Anthropic Claude API key. Get one at https://console.anthropic.com/
# If left empty, Project Nova runs in MOCK mode so the demo still works.
ANTHROPIC_API_KEY=

# Optional: override the default model.
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Optional: GitHub PAT for private repos (Test Generator GitHub fetch).
# Public files work without this. Fine-grained: Contents (read) on the target repos.
GITHUB_TOKEN=
